# raw/, wiki/ dir structure tracked via .gitkeep, contents ignored
raw/gamedocs/*
raw/gamedata/*
wiki/*
!raw/gamedocs/.gitkeep
!raw/gamedata/.gitkeep
!wiki/.gitkeep
!wiki/_meta/.gitkeep
!wiki/_tables/.gitkeep
!wiki/systems/.gitkeep
!wiki/activities/.gitkeep
!wiki/tables/.gitkeep
!wiki/numerical/.gitkeep
!wiki/combat/.gitkeep

